{
  "$schema": "https://biomejs.dev/schemas/2.2.0/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": ["**", "!node_modules", "!.next", "!dist", "!build", "!src/gen"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noUnknownAtRules": "off"
      }
    },
    "domains": {
      "next": "recommended",
      "react": "recommended"
    }
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "overrides": [
    {
      "includes": ["src/app/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["@/server/adapters", "@/server/adapters/**"],
                    "message": "Route/page/server code must reach the data plane only through userContext (@/server/context) — never an adapter, at any depth."
                  },
                  {
                    "group": ["@/server/authorized-backend"],
                    "message": "AuthorizedBackend is constructed only in @/server/context; route code holds it via userContext."
                  },
                  {
                    "group": ["@/server/identity", "@/server/identity/**"],
                    "message": "Identity is verified by the proxy and userContext; app code must not re-resolve it."
                  }
                ]
              }
            }
          }
        }
      }
    }
  ]
}
