# Python bytecode
__pycache__/
*.py[cod]

# Test / lint / type-check caches
.pytest_cache/
.ruff_cache/

# Coverage output
.coverage
htmlcov/

# Virtual environments
.venv/
venv/

# Editor / OS noise
.DS_Store
.idea/
.vscode/

# Claude Code: settings.json is tracked (team defaults); settings.local.json is per-dev, never committed
.claude/settings.local.json

# Claude Code worktrees (project-managed, created under .claude/ per CLAUDE.md)
.claude/worktrees/

# Local environment files
.env

# Node toolchain for schema/ (deps installed from the committed lockfile)
node_modules/
# Scratch TypeSpec output; committed artifacts live in schema/tests/jsonschema/
schema/.tsp-out/

# chuckd compat-gate scratch (bind-mounted into the chuckd container; kept
# repo-local so it sits inside the Docker runtime's host mount — see
# tools/schema/compat.py)
.chuckd-*/
